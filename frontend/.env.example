# ── Backend WebSocket URL ─────────────────────────────────────────
# Points to your Python FastAPI backend

# Local development (backend running on port 8080):
VITE_WS_URL=ws://localhost:8000

# Production (after deploying backend to Cloud Run):
# Use wss:// (secure WebSocket) for production — NOT ws://
# VITE_WS_URL=wss://research-agent-backend-abc123.run.app

# ── App Config ───────────────────────────────────────────────────
# Display name shown in the browser tab
VITE_APP_NAME=ResearchAI

# App version
VITE_APP_VERSION=1.0.0
