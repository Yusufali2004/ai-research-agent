# ================================================================
#  BACKEND — Environment Variables
#  1. Copy this file:  cp .env.example .env
#  2. Fill in values below
#  3. NEVER commit .env to GitHub — it contains secrets
# ================================================================

# ── Gemini API ───────────────────────────────────────────────────
# Get your FREE key at: https://aistudio.google.com
# Click "Get API Key" → "Create API key in new project"
GOOGLE_API_KEY=your_gemini_api_key_here

# Keep FALSE when using API key directly (not Vertex AI)
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# ── Voice Model ──────────────────────────────────────────────────
# Gemini Live API model for real-time voice
# Recommended:
DEMO_AGENT_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
# Alternative:
# DEMO_AGENT_MODEL=gemini-2.0-flash-live-001

# ── Server ───────────────────────────────────────────────────────
# Port FastAPI server runs on
# Note: Cloud Run sets PORT automatically in production
PORT=8080

# ── CORS (allowed frontend origins) ──────────────────────────────
# Local development — Vite default port:
FRONTEND_URL=http://localhost:5173

# Production — set this after Cloud Run deploy:
# FRONTEND_URL=https://your-frontend-service-abc123.run.app

# ── Google Cloud (production deployment only) ────────────────────
# Your GCP project ID (find it at console.cloud.google.com)
# GCP_PROJECT_ID=your-gcp-project-id

# Cloud Run deployment region
# GCP_REGION=us-central1
